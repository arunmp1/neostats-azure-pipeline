		{
			"name": "[concat(parameters('factoryName'), '/bronze_to_silver')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "Bronze_CSV",
								"type": "DatasetReference"
							},
							"name": "bronzesource"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "silver_clean_parquet",
								"type": "DatasetReference"
							},
							"name": "sink",
							"rejectedDataLinkedService": {
								"referenceName": "ADLS_neostats",
								"type": "LinkedServiceReference"
							}
						}
					],
					"transformations": [
						{
							"name": "castdatatypes"
						},
						{
							"name": "servermetadata"
						},
						{
							"name": "instancesize"
						},
						{
							"name": "MaskPII"
						},
						{
							"name": "addanomalyflag"
						},
						{
							"name": "selectrenamecolumns"
						},
						{
							"name": "AddDerivedColumns"
						},
						{
							"name": "deduplicate"
						},
						{
							"name": "removeinvalidcritical"
						},
						{
							"name": "keepvalidrecords"
						},
						{
							"name": "fillmissingvalues"
						}
					],
					"scriptLines": [
						"source(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> bronzesource",
						"bronzesource derive({CPU_Utilization (%)} = toDouble(replace(byName('CPU_Utilization (%)'), '%', '')),",
						"          {Memory_Usage (%)} = toDouble(replace(byName('Memory_Usage (%)'), '%', '')),",
						"          {Disk_IO (%)} = toDouble(replace(byName('Disk_IO (%)'), '%', '')),",
						"          {Network_Traffic_In (MB/s)} = toDouble(byName('Network_Traffic_In (MB/s)')),",
						"          {Network_Traffic_Out (MB/s)} = toDouble(byName('Network_Traffic_Out (MB/s)')),",
						"          {Uptime (Hours)} = toDouble(byName('Uptime (Hours)')),",
						"          {Downtime (Hours)} = toDouble(byName('Downtime (Hours)')),",
						"          Log_Timestamp = toTimestamp(byName('Log_Timestamp'), 'dd-MM-yyyy HH:mm')) ~> castdatatypes",
						"castdatatypes derive(Server_Role = regexReplace(regexExtract(lower(byName('Hostname')),'srv-([^-]+)',1),'[0-9]','')) ~> servermetadata",
						"keepvalidrecords derive(Instance_Size = iif(byName('Server_Role') == 'web','Medium',\r",
						"iif(byName('Server_Role') == 'app','Large',\r",
						"iif(byName('Server_Role') == 'database','XLarge',\r",
						"iif(byName('Server_Role') == 'backup','Large',\r",
						"iif(byName('Server_Role') == 'cache','Small',\r",
						"'Medium')))))) ~> instancesize",
						"instancesize derive(IP_Address = concat('MASKED_', left(md5(toString(byName('IP_Address'))),12)),",
						"          Admin_Email = concat('MASKED_', left(md5(toString(byName('Admin_Email'))),12)),",
						"          Admin_Phone = concat('MASKED_', left(md5(toString(byName('Admin_Phone'))),12)),",
						"          Admin_Name = concat('MASKED_', left(md5(toString(byName('Admin_Name'))),12))) ~> MaskPII",
