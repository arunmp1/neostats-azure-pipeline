						"    toDouble(byName('CPU_Utilization (%)')) > 75 ||\r",
						"    toDouble(byName('Memory_Usage (%)')) > 75 ||\r",
						"    toDouble(byName('Disk_IO (%)')) > 75,\r",
						"    'WARNING',\r",
						"    'NORMAL'\r",
						"  )\r",
