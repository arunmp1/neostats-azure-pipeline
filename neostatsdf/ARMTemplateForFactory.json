						"          total_network = first(byName('total_network')),",
						"          sla_breach = first(byName('sla_breach'))) ~> deduplicate",
						"servermetadata filter(!isNull(byName('Server_ID')) && ",
						"!isNull(byName('Hostname')) && ",
						"!isNull(byName('CPU_Utilization (%)')) && ",
						"!isNull(byName('Memory_Usage (%)')) && ",
						"!isNull(byName('Disk_IO (%)')) && ",
						"!isNull(byName('Log_Timestamp')) &&",
						"toDouble(byName('CPU_Utilization (%)')) <= 100 &&",
